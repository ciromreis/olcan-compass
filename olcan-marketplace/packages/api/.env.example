# Olcan Marketplace (MedusaJS) — Environment Variables
# Copy this to .env and fill in your values

# ============================================================
# Database — Use same PostgreSQL as main app (medusa schema)
# ============================================================
DATABASE_URL=postgresql://olcan_medusa:olcan_medusa_password@localhost:5432/olcan_dev?schema=medusa

# Production:
# DATABASE_URL=postgresql://user:password@host:5432/olcan_production

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# JWT & Cookies — MUST match FastAPI JWT_SECRET_KEY
# ============================================================
JWT_SECRET=REPLACE_WITH_SAME_SECRET_AS_FASTAPI
COOKIE_SECRET=REPLACE_WITH_SECURE_RANDOM_SECRET

# Generate with: openssl rand -base64 32

# ============================================================
# CORS — Allow app, marketing site, admin, and vendor portals
# ============================================================
STORE_CORS=http://localhost:3000,http://localhost:3001
ADMIN_CORS=http://localhost:7000
VENDOR_CORS=http://localhost:7001
AUTH_CORS=http://localhost:7000,http://localhost:7001

# Production:
# STORE_CORS=https://compass.olcan.com.br,https://www.olcan.com.br
# ADMIN_CORS=https://admin.olcan.com.br
# VENDOR_CORS=https://vendor.olcan.com.br
# AUTH_CORS=https://admin.olcan.com.br,https://vendor.olcan.com.br

# ============================================================
# Stripe Payment Provider
# ============================================================
STRIPE_API_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET

# Production:
# STRIPE_API_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# Admin User (for initial setup)
# ============================================================
ADMIN_EMAIL=admin@olcan.com.br
ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
