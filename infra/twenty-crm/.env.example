# Twenty CRM — production env (place at /opt/twenty-crm/.env on the VM)
#
# Generate APP_SECRET with: openssl rand -base64 48
# Generate PG_DATABASE_PASSWORD with: openssl rand -hex 32

APP_SECRET=__generate_with_openssl_rand_base64_48__
SERVER_URL=https://crm.olcan.com.br

PG_DATABASE_USER=twenty
PG_DATABASE_PASSWORD=__generate_with_openssl_rand_hex_32__
PG_DATABASE_NAME=twenty

# Pin a release tag — do NOT use latest in production.
# Check https://github.com/twentyhq/twenty/releases for the current tag.
TAG=v0.32.0
