# Olcan Edge VPS — environment template
#
# Copy to /opt/olcan-edge/.env on the VPS. Never commit a filled .env.
# Generate fresh secrets ONLY for a brand-new install. For migrations,
# copy the existing values from the source VM (see README.md).

# ─── Image tags (pin in production) ──────────────────────────────────
N8N_TAG=1.123.5
TWENTY_TAG=v0.32.0

# ─── Let's Encrypt ───────────────────────────────────────────────────
LETSENCRYPT_EMAIL=admin@olcan.com.br

# ─── n8n ─────────────────────────────────────────────────────────────
# IMPORTANT: For migrations, this MUST match the source VM exactly.
# Losing this key permanently bricks every encrypted credential in n8n.
# Source VM (35.238.150.117): UTm/dOCgC+kjYVUbHIiHA5WPBo+tXx/8
N8N_ENCRYPTION_KEY=

N8N_DB_USER=n8n
N8N_DB_NAME=n8n
# Source VM password: OlcanDB_2026_Secure!
N8N_DB_PASSWORD=

# ─── Twenty CRM ──────────────────────────────────────────────────────
# Generate (fresh install only): openssl rand -base64 48
TWENTY_APP_SECRET=

TWENTY_DB_USER=twenty
TWENTY_DB_NAME=twenty
# Generate (fresh install): openssl rand -hex 32
TWENTY_DB_PASSWORD=
