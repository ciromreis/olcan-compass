# Olcan Compass V2.5 — Environment Variables
# Copy this to .env.local and fill in your values

# ============================================================
# App URLs
# ============================================================
NEXT_PUBLIC_APP_URL=https://compass.olcan.com.br
NEXT_PUBLIC_API_URL=https://api.compass.olcan.com.br/api/v1
NEXT_PUBLIC_MARKETPLACE_API_URL=https://marketplace.olcan.com.br
NEXT_PUBLIC_CMS_URL=https://www.olcan.com.br
NEXT_PUBLIC_ZENITH_API_URL=https://zenith.olcan.com.br/api

# Development overrides:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1
# NEXT_PUBLIC_MARKETPLACE_API_URL=http://localhost:9000
# NEXT_PUBLIC_CMS_URL=http://localhost:3001
# NEXT_PUBLIC_ZENITH_API_URL=http://localhost:3001/api

# ============================================================
# Supabase (Optional — if using Supabase Auth)
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Stripe (Payments & Escrow)
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Production:
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...

# ============================================================
# Google Vertex AI (Gemini)
# ============================================================
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================================
# Feature Flags
# ============================================================
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true
# Optional: sent with product analytics events (e.g. git SHA or semver)
# NEXT_PUBLIC_APP_VERSION=2.5.0

# Product surface (stub / experimental UI). Defaults: all false except where noted.
# Set to true or 1 to enable.
# NEXT_PUBLIC_FEATURE_GUILDS=false
# NEXT_PUBLIC_FEATURE_GAMIFICATION_HUB=false
# NEXT_PUBLIC_FEATURE_NUDGE_ENGINE=false
# NEXT_PUBLIC_FEATURE_FORGE_LAB=false
