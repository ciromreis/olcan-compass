# API
APP_NAME=olcan-compass-api
ENV=development
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000

# NOTE (dev): transactional emails are not configured yet.
# When ENV != production, the password reset endpoint may return a `reset_url`
# to allow local testing without email delivery.

# CORS (comma-separated, add production domains for deployed environments)
# Production: https://olcan-compass-web.netlify.app,https://compass.olcan.com.br
CORS_ALLOW_ORIGINS=http://localhost:3000

# Database
# Development (local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://olcan_app:olcan_app_password@localhost:5432/olcan_dev

# Production
# DATABASE_URL=postgresql+asyncpg://olcan_app:SECURE_PASSWORD@host:5432/olcan_production

# Redis and Celery
REDIS_URL=redis://redis:6379/0

# JWT - Generate a secure random string for production
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password settings
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBER=true

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Frontend / transactional email
FRONTEND_URL=http://localhost:3000
EMAIL_FROM=noreply@olcan.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Stripe Connect (for escrow)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Encryption (for PII hashing)
ENCRYPTION_KEY=your-32-byte-encryption-key-change-in-production

# Feature Flags
FEATURE_CREDENTIALS_ENABLED=true
FEATURE_TEMPORAL_MATCHING_ENABLED=true
FEATURE_OPPORTUNITY_COST_ENABLED=true
FEATURE_ESCROW_ENABLED=true
FEATURE_SCENARIO_OPTIMIZATION_ENABLED=true

# ============================================================
# V2 — Supabase (Auth + pgvector)
# ============================================================
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ============================================================
# V2 — Google Vertex AI (Gemini 1.5 Pro)
# ============================================================
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# VERTEX_AI_LOCATION=us-central1

# ============================================================
# V2 — Inngest (Event-Driven Orchestration)
# ============================================================
# INNGEST_EVENT_KEY=your-inngest-event-key
# INNGEST_SIGNING_KEY=your-inngest-signing-key

# ============================================================
# Commerce Bridge (MedusaJS Integration)
# ============================================================
MARKETPLACE_ENGINE_URL=http://localhost:9000
MARKETPLACE_PUBLISHABLE_KEY=pk_REPLACE_WITH_MEDUSA_KEY
COMMERCE_CATALOG_URL=https://www.olcan.com.br/marketplace
COMMERCE_CHECKOUT_CURSO_CIDADAO_MUNDO_URL=https://pay.hotmart.com/curso-cidadao-mundo
COMMERCE_CHECKOUT_KIT_APPLICATION_URL=https://pay.hotmart.com/kit-application
COMMERCE_CHECKOUT_ROTA_INTERNACIONALIZACAO_URL=https://pay.hotmart.com/rota-internacionalizacao

# ============================================================
# Commerce Bridge (MedusaJS Integration)
# ============================================================
MARKETPLACE_ENGINE_URL=http://localhost:9000
MARKETPLACE_PUBLISHABLE_KEY=pk_REPLACE_WITH_MEDUSA_KEY
COMMERCE_CATALOG_URL=https://www.olcan.com.br/marketplace
COMMERCE_CHECKOUT_CURSO_CIDADAO_MUNDO_URL=https://pay.hotmart.com/curso-cidadao-mundo
COMMERCE_CHECKOUT_KIT_APPLICATION_URL=https://pay.hotmart.com/kit-application
COMMERCE_CHECKOUT_ROTA_INTERNACIONALIZACAO_URL=https://pay.hotmart.com/rota-internacionalizacao
