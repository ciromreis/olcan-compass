# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.olcan.com.br

# API URLs
NEXT_PUBLIC_API_URL=https://api.olcan.com.br/api/v1
NEXT_PUBLIC_MARKETPLACE_API_URL=https://marketplace.olcan.com.br

# Mercur Marketplace
NEXT_PUBLIC_MEDUSA_URL=https://marketplace.olcan.com.br
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key_here

# Email
EMAIL_FROM=contato@olcan.com.br

# Payload CMS (REQUIRED for /admin panel to work)
# Generate secrets with: openssl rand -base64 32
# For production, use managed PostgreSQL database
PAYLOAD_SECRET=your-secure-payload-secret-min-32-chars-replace-me
JWT_SECRET=your-secure-jwt-secret-min-32-chars-replace-me
DATABASE_URI=postgresql://user:password@host:5432/database?schema=payload

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Site Verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Mautic Marketing Automation (optional)
NEXT_PUBLIC_MAUTIC_URL=https://mautic.olcan.com.br

# Meta/Facebook Pixel (optional)
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id

# Google Ads (optional)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
