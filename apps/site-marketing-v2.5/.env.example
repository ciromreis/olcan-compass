# ============================================================
# Olcan Site Marketing v2.5 — Environment Variables
# ============================================================
# Copy to .env.local and fill in the values marked PREENCHER.
# For Vercel deploy: Settings > Environment Variables
# ============================================================

# === Site Configuration ===
NEXT_PUBLIC_SITE_URL=https://olcan.com.br

# === API URLs ===
NEXT_PUBLIC_API_URL=https://olcan-compass-api.onrender.com/api/v1
NEXT_PUBLIC_MARKETPLACE_API_URL=https://compass.olcan.com.br/api/marketplace
NEXT_PUBLIC_APP_URL=https://compass.olcan.com.br

# === Mercur / MedusaJS Marketplace ===
NEXT_PUBLIC_MEDUSA_URL=https://compass.olcan.com.br
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key_here

# === Payload CMS (required for /admin panel) ===
# Render PostgreSQL: use same DB with 'payload' schema for isolation
# Format: postgresql+asyncpg://user:pass@host:5432/db?schema=payload
# Or standard: postgresql://user:pass@host:5432/db?schema=payload
DATABASE_URI=postgresql+asyncpg://user:password@host:5432/database?schema=payload
EMAIL_FROM=contato@olcan.com.br
# Generated with: openssl rand -hex 32
JWT_SECRET=8f7e6d5c4b3a2918f7e6d5c4b3a2918f7e6d5c4b3a2918f7e6d5c4b3a291
PAYLOAD_SECRET=9a8b7c6d5e4f3a2b1c9a8b7c6d5e4f3a2b1c9a8b7c6d5e4f3a2b1c9a8b7c

# === Google Analytics 4 ===
# Property: Olcan - Site institucional
# Where: analytics.google.com > Admin > Data Streams > Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# === Meta Pixel ===
# Get from: Meta Business Manager > Eventos > Pixel > ID
# Current value: 941115425475831
NEXT_PUBLIC_META_PIXEL_ID=941115425475831

# === Mautic Marketing Automation ===
# Where: mautic.olcan.com.br
NEXT_PUBLIC_MAUTIC_URL=https://mautic.olcan.com.br
# Form ID from: https://mautic.olcan.com.br/s/forms/view/1
NEXT_PUBLIC_MAUTIC_FORM_ID=1

# === n8n Webhook (lead routing) ===
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://n8n.olcan.com.br/webhook/site-lead
N8N_WEBHOOK_SECRET=your-webhook-secret

# === Google Ads (optional, Q2) ===
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX

# === Google Site Verification (optional) ===
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code
