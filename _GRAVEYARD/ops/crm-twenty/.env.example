# Twenty (self-host) — environment example
#
# Copy to `.env` and fill with secure values.
# Docs: https://docs.twenty.com/developers/self-host/capabilities/docker-compose

# Version tag for the twentycrm/twenty image
TAG=latest

# Public URL (must match reverse proxy + subdomain)
SERVER_URL=https://crm.olcan.com.br

# Required secret (generate: `openssl rand -base64 32`)
APP_SECRET=replace_me_with_a_random_string

# Postgres
PG_DATABASE_NAME=twenty
PG_DATABASE_USER=twenty
PG_DATABASE_PASSWORD=change_me_no_special_chars
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432

# Redis
REDIS_URL=redis://redis:6379

# Optional: disable migrations if you manage them separately
# DISABLE_DB_MIGRATIONS=

