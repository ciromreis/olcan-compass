{
  "name": "olcan-compass",
  "private": true,
  "version": "2.0.0",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev:v1": "pnpm --filter @olcan/web dev -- --host 0.0.0.0 --port 3000",
    "dev:v2": "pnpm --filter @olcan/web-v2 dev",
    "build:v1": "pnpm --filter @olcan/web build",
    "build:v2": "pnpm --filter @olcan/web-v2 build",
    "lint:v1": "pnpm --filter @olcan/web lint",
    "lint:v2": "pnpm --filter @olcan/web-v2 lint",
    "dev": "pnpm dev:v2",
    "build": "pnpm build:v2",
    "lint": "pnpm lint:v2",
    "health:api": "curl -sS http://localhost:8000/api/health",
    "smoke:auth": "node ./scripts/smoke/auth.js",
    "seed:user": "node ./scripts/seed/user.js"
  },
  "dependencies": {
    "styled-jsx": "5.1.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "next": "14.2.35"
  },
  "pnpm": {
    "overrides": {
      "styled-jsx": "5.1.1"
    },
    "packageExtensions": {
      "next": {
        "dependencies": {
          "styled-jsx": "5.1.1"
        }
      }
    }
  }
}
